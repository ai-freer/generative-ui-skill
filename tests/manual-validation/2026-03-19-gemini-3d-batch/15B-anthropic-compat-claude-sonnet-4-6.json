\"context-stroke\\\" stroke-width=\\\"1.5\\\" stroke-linecap=\\\"round\\\" stroke-linejoin=\\\"round\\\"/></marker></defs>\\n<g font-family=\\\"system-ui,-apple-system,sans-serif\\\">\\n  <text x=\\\"340\\\" y=\\\"24\\\" text-anchor=\\\"middle\\\" font-size=\\\"13\\\" fill=\\\"var(--color-text-secondary)\\\">半保留复制：每条子链保留一条亲代链</text>\\n  <path d=\\\"M80,60 C110,60 110,180 140,180 C170,180 170,60 200,60 C230,60 230,180 260,180\\\" fill=\\\"none\\\" stroke=\\\"#7F77DD\\\" stroke-width=\\\"3\\\" stroke-linecap=\\\"round\\\"/>\\n  <path d=\\\"M80,180 C110,180 110,60 140,60 C170,60 170,180 200,180 C230,180 230,60 260,60\\\" fill=\\\"none\\\" stroke=\\\"#D85A30\\\" stroke-width=\\\"3\\\" stroke-linecap=\\\"round\\\" stroke-dasharray=\\\"6 3\\\"/>\\n  <text x=\\\"170\\\" y=\\\"220\\\" text-anchor=\\\"middle\\\" font-size=\\\"12\\\" font-weight=\\\"500\\\" fill=\\\"#3C3489\\\">子代双链 1</text>\\n  <text x=\\\"170\\\" y=\\\"235\\\" text-anchor=\\\"middle\\\" font-size=\\\"11\\\" fill=\\\"var(--color-text-secondary)\\\">紫=亲代 橙=新链</text>\\n  <path d=\\\"M400,60 C430,60 430,180 460,180 C490,180 490,60 520,60 C550,60 550,180 580,180\\\" fill=\\\"none\\\" stroke=\\\"#1D9E75\\\" stroke-width=\\\"3\\\" stroke-linecap=\\\"round\\\"/>\\n  <path d=\\\"M400,180 C430,180 430,60 460,60 C490,60 490,180 520,180 C550,180 550,60 580,60\\\" fill=\\\"none\\\" stroke=\\\"#D85A30\\\" stroke-width=\\\"3\\\" stroke-linecap=\\\"round\\\" stroke-dasharray=\\\"6 3\\\"/>\\n  <text x=\\\"490\\\" y=\\\"220\\\" text-anchor=\\\"middle\\\" font-size=\\\"12\\\" font-weight=\\\"500\\\" fill=\\\"#085041\\\">子代双链 2</text>\\n  <text x=\\\"490\\\" y=\\\"235\\\" text-anchor=\\\"middle\\\" font-size=\\\"11\\\" fill=\\\"var(--color-text-secondary)\\\">绿=亲代 橙=新链</text>\\n  <line x1=\\\"300\\\" y1=\\\"60\\\" x2=\\\"360\\\" y2=\\\"60\\\" stroke=\\\"var(--color-border-secondary)\\\" stroke-width=\\\"1\\\" stroke-dasharray=\\\"4 3\\\"/>\\n  <line x1=\\\"300\\\" y1=\\\"180\\\" x2=\\\"360\\\" y2=\\\"180\\\" stroke=\\\"var(--color-border-secondary)\\\" stroke-width=\\\"1\\\" stroke-dasharray=\\\"4 3\\\"/>\\n  <text x=\\\"330\\\" y=\\\"128\\\" text-anchor=\\\"middle\\\" font-size=\\\"20\\\" fill=\\\"var(--color-text-secondary)\\\">→</text>\\n  <rect x=\\\"100\\\" y=\\\"248\\\" width=\\\"14\\\" height=\\\"8\\\" rx=\\\"2\\\" fill=\\\"#7F77DD\\\"/>\\n  <text x=\\\"120\\\" y=\\\"256\\\" font-size=\\\"11\\\" fill=\\\"var(--color-text-secondary)\\\">亲代链</text>\\n  <rect x=\\\"200\\\" y=\\\"248\\\" width=\\\"14\\\" height=\\\"8\\\" rx=\\\"2\\\" fill=\\\"#1D9E75\\\"/>\\n  <text x=\\\"220\\\" y=\\\"256\\\" font-size=\\\"11\\\" fill=\\\"var(--color-text-secondary)\\\">亲代链</text>\\n  <rect x=\\\"300\\\" y=\\\"248\\\" width=\\\"14\\\" height=\\\"8\\\" rx=\\\"2\\\" fill=\\\"#D85A30\\\"/>\\n  <text x=\\\"320\\\" y=\\\"256\\\" font-size=\\\"11\\\" fill=\\\"var(--color-text-secondary)\\\">新合成链</text>\\n</g>\\n</svg>`\\n  }\\n];\\n\\nlet current = 0;\\n\\nfunction render() {\\n  const panelsEl = document.getElementById('panels');\\n  const dotsEl = document.getElementById('dots');\\n  panelsEl.innerHTML = '';\\n  dotsEl.innerHTML = '';\\n\\n  steps.forEach((s, i) => {\\n    const div = document.createElement('div');\\n    div.className = 'step-panel' + (i === current ? ' active' : '');\\n    div.innerHTML = `\\n      <div style=\\\"background:${s.color};border-radius:12px;padding:1rem 1.25rem;margin-bottom:0.75rem;\\\">\\n        <div style=\\\"font-size:15px;font-weight:500;color:${s.titleColor};margin-bottom:4px;\\\">${s.label}</div>\\n      </div>\\n      <div>${s.svg}</div>\\n    `;\\n    panelsEl.appendChild(div);\\n\\n    const dot = document.createElement('span');\\n    dot.className = 'dot' + (i === current ? ' active' : '');\\n    dot.onclick = () => { current = i; render(); };\\n    dotsEl.appendChild(dot);\\n  });\\n}\\n\\nfunction changeStep(dir) {\\n  current = (current + dir + steps.length) % steps.length;\\n  render();\\n}\\n\\nrender();\\n</script>\"}\n```\n\n点击任意步骤的圆点可以跳转，或用左右按钮逐步浏览。整个过程遵循**半保留复制**原则——每条子代双链都保留一条亲代链，这一机制由Meselson和Stahl在1958年通过氮同位素实验证实。"
