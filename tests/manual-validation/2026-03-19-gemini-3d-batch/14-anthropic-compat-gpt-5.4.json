  "text": "太阳系运行的核心是：行星在太阳引力主导下沿各自轨道公转，同时很多天体也会自转。内侧行星轨道更小、运行更快；外侧行星轨道更大、运行更慢。下面这个 3D 模型把这个规律做成了可旋转、可暂停、可调速的演示。\n\n```show-widget\n{\"title\":\"solar_system_3d_model\",\"widget_code\":\"<style>canvas{display:block;width:100%!important;height:420px!important}#controls{display:flex;align-items:center;gap:12px;padding:10px 0 0;font-size:13px;color:var(--color-text-secondary);flex-wrap:wrap}#controls label{display:flex;align-items:center;gap:8px;flex:1;min-width:180px}#hint{font-size:12px;color:var(--color-text-tertiary);padding-top:6px}</style><canvas id=\\\"c\\\"></canvas><div id=\\\"controls\\\"><button id=\\\"playBtn\\\" onclick=\\\"togglePlay()\\\">暂停</button><button onclick=\\\"setView('top')\\\">俯视</button><button onclick=\\\"setView('side')\\\">侧视</button><button onclick=\\\"setView('front')\\\">正视</button><label>速度 <input type=\\\"range\\\" min=\\\"1\\\" max=\\\"10\\\" step=\\\"1\\\" value=\\\"5\\\" oninput=\\\"setSpeed(this.value)\\\" style=\\\"flex:1\\\"><span id=\\\"speedOut\\\">1.0x</span></label><span id=\\\"focusLabel\\\" style=\\\"min-width:120px\\\">当前: 全景</span></div><div id=\\\"hint\\\">可拖拽旋转视角，点击行星查看细节。</div><script src=\\\"https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js\\\"></script><script src=\\\"https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js\\\" onload=\\\"init()\\\"></script><script>var scene,camera,renderer,controls,canvas;var planets=[];var orbitMeshes=[];var speedMul=1;var playing=true;var raycaster=new THREE.Raycaster();var mouse=new THREE.Vector2();var dragDist=0,startX=0,startY=0;function init(){if(!window.THREE||!THREE.OrbitControls)return;canvas=document.getElementById('c');var W=canvas.clientWidth,H=420;renderer=new THREE.WebGLRenderer({canvas:canvas,antialias:true,alpha:true});renderer.setSize(W,H);renderer.setPixelRatio(Math.min(devicePixelRatio,2));scene=new THREE.Scene();camera=new THREE.PerspectiveCamera(45,W/H,0.1,1000);camera.position.set(0,18,28);scene.add(new THREE.AmbientLight(0xffffff,0.72));var sunLight=new THREE.DirectionalLight(0xffffff,0.95);sunLight.position.set(8,12,8);scene.add(sunLight);controls=new THREE.OrbitControls(camera,canvas);controls.enableDamping=true;controls.dampingFactor=0.08;controls.autoRotate=true;controls.autoRotateSpeed=0.45;buildScene();window.addEventListener('resize',onResize);canvas.addEventListener('mousedown',function(e){startX=e.clientX;startY=e.clientY;dragDist=0});canvas.addEventListener('mousemove',function(e){dragDist=Math.abs(e.clientX-startX)+Math.abs(e.clientY-startY)});canvas.addEventListener('click',onClick);animate()}function buildScene(){var sunGeo=new THREE.SphereGeometry(1.9,24,18);var sunMat=new THREE.MeshBasicMaterial({color:0xEF9F27});var sun=new THREE.Mesh(sunGeo,sunMat);sun.name='太阳';scene.add(sun);var sunGlow=new THREE.Mesh(new THREE.SphereGeometry(2.4,24,18),new THREE.MeshBasicMaterial({color:0xFAC775,transparent:true,opacity:0.18}));scene.add(sunGlow);var defs=[{name:'水星',color:0x888780,size:0.33,orbit:4.2,speed:4.15,tilt:0.02,msg:'详细介绍水星的轨道和特点'},{name:'金星',color:0xD85A30,size:0.52,orbit:6.2,speed:1.62,tilt:3.09,msg:'详细介绍金星的轨道和特点'},{name:'地球',color:0x378ADD,size:0.56,orbit:8.6,speed:1.0,tilt:0.41,msg:'详细介绍地球的公转、自转和四季'},{name:'火星',color:0xE24B4A,size:0.44,orbit:11.3,speed:0.53,tilt:0.44,msg:'详细介绍火星的轨道和特点'},{name:'木星',color:0x639922,size:1.22,orbit:15.2,speed:0.08,tilt:0.05,msg:'详细介绍木星的轨道和特点'},{name:'土星',color:0xC0DD97,size:1.02,orbit:19.5,speed:0.03,tilt:0.47,msg:'详细介绍土星光环和轨道特点'},{name:'天王星',color:0x1D9E75,size:0.76,orbit:23.1,speed:0.012,tilt:1.71,msg:'详细介绍天王星的轨道和特点'},{name:'海王星',color:0x7F77DD,size:0.74,orbit:26.6,speed:0.006,tilt:0.49,msg:'详细介绍海王星的轨道和特点'}];defs.forEach(function(d,i){var orbit=new THREE.Mesh(new THREE.RingGeometry(d.orbit-0.03,d.orbit+0.03,96),new THREE.MeshBasicMaterial({color:0x888780,side:THREE.DoubleSide,transparent:true,opacity:0.2}));orbit.rotation.x=-Math.PI/2;scene.add(orbit);orbitMeshes.push(orbit);var mesh=new THREE.Mesh(new THREE.SphereGeometry(d.size,18,14),new THREE.MeshLambertMaterial({color:d.color}));mesh.position.set(d.orbit,0,0);mesh.rotation.z=d.tilt;mesh.name=d.name;mesh.userData={orbit:d.orbit,speed:d.speed,angle:i*0.75,size:d.size,msg:d.msg};scene.add(mesh);if(d.name==='土星'){var ring=new THREE.Mesh(new THREE.RingGeometry(d.size+0.24,d.size+0.5,48),new THREE.MeshBasicMaterial({color:0xFAC775,side:THREE.DoubleSide,transparent:true,opacity:0.55}));ring.rotation.x=Math.PI/2.5;mesh.add(ring)}planets.push(mesh)});var axesMat=new THREE.LineBasicMaterial({color:0x888780,transparent:true,opacity:0.18});var xPts=[new THREE.Vector3(-30,0,0),new THREE.Vector3(30,0,0)];var zPts=[new THREE.Vector3(0,0,-30),new THREE.Vector3(0,0,30)];scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(xPts),axesMat));scene.add(new THREE.Line(new THREE.BufferGeometry().setFromPoints(zPts),axesMat))}function animate(){requestAnimationFrame(animate);if(playing){planets.forEach(function(p){p.userData.angle+=0.0035*p.userData.speed*speedMul;p.position.set(Math.cos(p.userData.angle)*p.userData.orbit,0,Math.sin(p.userData.angle)*p.userData.orbit);p.rotation.y+=0.01})}controls.update();renderer.render(scene,camera)}function onResize(){if(!renderer||!camera)return;var W=canvas.clientWidth,H=420;renderer.setSize(W,H);camera.aspect=W/H;camera.updateProjectionMatrix()}function setSpeed(v){speedMul=Number(v)/5;document.getElementById('speedOut').textContent=speedMul.toFixed(1)+'x'}function togglePlay(){playing=!playing;document.getElementById('playBtn').textContent=playing?'暂停':'播放'}function setView(v){var pos={top:[0,34,0.1],side:[34,10,0],front:[0,10,34]}[v];camera.position.set(pos[0],pos[1],pos[2]);camera.lookAt(0,0,0);controls.target.set(0,0,0);controls.update();document.getElementById('focusLabel').textContent='当前: '+(v==='top'?'俯视':v==='side'?'侧视':'正视')}function onClick(e){if(dragDist>5)return;var rect=canvas.getBoundingClientRect();mouse.x=((e.clientX-rect.left)/rect.width)*2-1;mouse.y=-((e.clientY-rect.top)/rect.height)*2+1;raycaster.setFromCamera(mouse,camera);var hits=raycaster.intersectObjects(planets);if(hits.length){var obj=hits[0].object;document.getElementById('focusLabel').textContent='当前: '+obj.name;window.__widgetSendMessage(obj.userData.msg)}}if(window.THREE&&THREE.OrbitControls)init();</script>\"}\n```\n\n这个模型重点展示了 3 个规律：轨道半径不同、运行速度不同、视角变化后仍能看出“近快远慢”。如果你想，我还可以继续做一版“带黄道面倾角、月球绕地、公转周期对比”的更细化 3D 演示。"
