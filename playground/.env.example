# Provider API keys (至少配置一个即可使用对应 Provider)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# KIMI_API_KEY=...
# KIMI_CODING_API_KEY=sk-kimi-...
# ZHIPU_API_KEY=...
# VOLCENGINE_API_KEY=...

# 可选：Anthropic 代理 base URL，不设则使用官方
# ANTHROPIC_BASE_URL=https://ai.ltcraft.cn:443

# 可选：服务端口，默认 3456
# PORT=3456

# 可选：Serper 联网搜索 API Key（启用搜索功能需要）
# https://serper.dev — Google Search API
# SERPER_API_KEY=...
