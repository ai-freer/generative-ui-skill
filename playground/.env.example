# API key (required). 官方 Anthropic 或兼容 Anthropic API 的第三方均可
# ANTHROPIC_API_KEY=sk-ant-...

# 可选：兼容 Anthropic API 的第三方 base URL，不设则使用 Anthropic 官方
# ANTHROPIC_BASE_URL=https://your-api-proxy.com/v1

# 可选：模型 ID。示例：claude-sonnet-4-6 / claude-opus-4-6 / gpt-5.4 / gemini-3.1-pro
# ANTHROPIC_MODEL=claude-sonnet-4-6

# 可选：服务端口，默认 3456
# PORT=3456
