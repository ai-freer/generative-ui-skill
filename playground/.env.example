# ============================================================
# Native Providers — 填入 API Key 即可使用官方服务
# ============================================================

# Anthropic（官方）
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI（官方）
# OPENAI_API_KEY=sk-...

# Google Gemini（官方，OpenAI 兼容接口）
# GOOGLE_API_KEY=...

# ============================================================
# 预制 Providers — 填入对应 Key 即可启用
# ============================================================

# MiniMax
# MINIMAX_API_KEY=...

# OpenRouter（需同时配置模型列表）
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODELS=anthropic/claude-sonnet-4,google/gemini-2.5-pro

# Kimi (Moonshot)
# KIMI_API_KEY=...

# Kimi Coding
# KIMI_CODING_API_KEY=sk-kimi-...

# 智谱 GLM
# ZHIPU_API_KEY=...

# 火山引擎 / 豆包
# VOLCENGINE_API_KEY=...

# ============================================================
# Anthropic 兼容中转站 — 所有字段均通过环境变量配置
# ============================================================
# ANTHROPIC_COMPAT_NAME=MyProxy
# ANTHROPIC_COMPAT_BASE_URL=https://your-proxy.example.com
# ANTHROPIC_COMPAT_API_KEY=sk-...
# ANTHROPIC_COMPAT_MODELS=claude-opus-4-6,claude-sonnet-4-6

# ============================================================
# OpenAI 兼容中转站 — 所有字段均通过环境变量配置
# ============================================================
# OPENAI_COMPAT_NAME=MyRelay
# OPENAI_COMPAT_BASE_URL=https://your-relay.example.com/v1
# OPENAI_COMPAT_API_KEY=sk-...
# OPENAI_COMPAT_MODELS=gpt-4.1,gpt-4.1-mini

# ============================================================
# 其他设置
# ============================================================

# 可选：服务端口，默认 3456
# PORT=3456

# 可选：API 超时（毫秒），默认 300000
# API_TIMEOUT_MS=300000

# 可选：Serper 联网搜索 API Key（启用搜索功能需要）
# https://serper.dev — Google Search API
# SERPER_API_KEY=...
